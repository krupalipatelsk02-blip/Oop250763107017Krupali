class Point {
    int x, y;

    // Default constructor
    Point() {
        x = 5;
        y = 5;
    }

    // Parameterized constructor
    Point(int x, int y) {
        this.x = x;
        this.y = y;
    }

    // Copy constructor
    Point(Point p) {
        this.x = p.x;
        this.y = p.y;
    }

    // Display method
    void display() {
        System.out.println("(" + x + ", " + y + ")");
    }

    public static void main(String[] args) {
        Point p1 = new Point();          // default
        Point p2 = new Point(10, 20);    // parameterized
        Point p3 = new Point(p2);        // copy

        p1.display();
        p2.display();
        p3.display();
    }
}